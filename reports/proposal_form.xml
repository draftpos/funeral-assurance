<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_proposal_form" model="ir.actions.report">
        <field name="name">Proposal Application Form</field>
        <field name="model">funeral.proposal</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">funeral_assurance.report_proposal_form_template</field>
        <field name="report_file">funeral_assurance.report_proposal_form_template</field>
        <field name="print_report_name">'Proposal Application - %s' % (object.name)</field>
        <field name="binding_model_id" ref="model_funeral_proposal"/>
        <field name="binding_type">report</field>
        <field name="binding_view_types">form</field>
    </record>

    <template id="report_proposal_form_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: Arial, sans-serif; font-size: 11px;">
                        
                        <!-- Header / Logo Area -->
                        <div class="row mb-3">
                            <div class="col-6 text-left">
                                <!-- Logo Placeholder -->
                                <h4 style="color: #0077b6; font-weight: bold; margin-bottom: 0;">Ruvimbo</h4>
                                <h5 style="color: #0077b6; margin-top: 0;">Funeral</h5>
                                <p style="margin: 0; font-size: 10px;">Assurance (Pvt) Ltd</p>
                                <p style="font-style: italic; font-size: 9px; color: #0077b6;">"Experience the difference"</p>
                            </div>
                            <div class="col-6 text-end">
                                <div style="font-size: 8px; margin-top: 10px;">
                                    Head Office<br/>
                                    1122 Tynwald South<br/>
                                    Industrial Area, Harare<br/>
                                    Call: +263 777 887 549<br/>
                                    Email: info@ruvimboholdings.co.zw
                                </div>
                            </div>
                        </div>

                        <!-- Main Table -->
                        <table style="width: 100%; border-collapse: collapse; border: 2px solid #0077b6;">
                            <!-- Row 1 -->
                            <tr>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;"><strong>MR/MRS/MISS:</strong> <span t-field="o.title"/></td>
                                <td colspan="3" style="border: 1px solid #0077b6; padding: 4px;"><strong>PHYSICAL ADDRESS:</strong> <span t-field="o.residential_address"/></td>
                            </tr>
                            <!-- Row 2 -->
                            <tr>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;"><strong>SURNAME:</strong> <span t-field="o.last_name"/></td>
                                <td colspan="3" style="border: 1px solid #0077b6; padding: 4px;"><strong>BUSINESS ADDRESS:</strong> <span t-field="o.business_address"/></td>
                            </tr>
                            <!-- Row 3 -->
                            <tr>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;"><strong>FIRST NAME:</strong> <span t-field="o.first_name"/></td>
                                <td colspan="3" style="border: 1px solid #0077b6; padding: 4px;"><strong>EMPLOYER:</strong> <span t-field="o.employer"/></td>
                            </tr>
                            <!-- Row 4 -->
                            <tr>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;">
                                    <div class="row">
                                        <div class="col-6"><strong>GROSS SALARY:</strong> <span t-field="o.gross_salary"/></div>
                                        <div class="col-6"><strong>NET SALARY:</strong> <span t-field="o.net_salary"/></div>
                                    </div>
                                </td>
                                <td colspan="3" style="border: 1px solid #0077b6; padding: 4px;"><strong>OCCUPATION:</strong> <span t-field="o.occupation"/></td>
                            </tr>
                            <!-- Row 5 -->
                            <tr>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;"><strong>ID No:</strong> <span t-field="o.national_id"/></td>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;"><strong>TEL &amp; CELL:</strong> <span t-field="o.home_phone"/></td>
                                <td style="border: 1px solid #0077b6; padding: 4px;"><strong>Date of 1st Payment:</strong> <span t-field="o.first_payment_date"/></td>
                            </tr>

                            <!-- Middle Section -->
                            <tr>
                                <td rowspan="2" style="border: 1px solid #0077b6; padding: 4px; vertical-align: top;">
                                    <strong>MODE OF PAYMENT</strong><br/>
                                    CASH [ <t t-if="o.mode_of_payment == 'cash'">X</t> ] <br/>
                                    S/O [ <t t-if="o.mode_of_payment == 'stop_order'">X</t> ]
                                </td>
                                <td rowspan="2" style="border: 1px solid #0077b6; padding: 4px; vertical-align: top;">
                                    <strong>PRODUCT NAME:</strong> <br/><span t-field="o.product_id.name"/>
                                </td>
                                <td rowspan="2" style="border: 1px solid #0077b6; padding: 4px; vertical-align: top;">
                                    <strong>PLAN TYPE:</strong> <br/><span t-field="o.plan_type"/>
                                </td>
                                <td rowspan="2" style="border: 1px solid #0077b6; padding: 4px; vertical-align: top;">
                                    <strong>FREQUENCY</strong><br/>
                                    MONTHLY [ <t t-if="o.frequency == 'monthly'">X</t> ]<br/>
                                    QUARTERLY [ <t t-if="o.frequency == 'quarterly'">X</t> ]<br/>
                                    YEARLY [ <t t-if="o.frequency == 'yearly'">X</t> ]
                                </td>
                                <td style="border: 1px solid #0077b6; padding: 10px; text-align: center; vertical-align: middle;">
                                    <strong>MEMBERSHIP NUMBER</strong><br/>
                                    <div style="border: 1px solid black; padding: 5px; font-size: 14px; font-weight: bold; letter-spacing: 2px;">
                                        <span t-field="o.name"/>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td style="border: 1px solid #0077b6; padding: 4px;">
                                    <div class="row">
                                        <div class="col-6"><strong>NAME:</strong> <span t-field="o.first_name"/></div>
                                        <div class="col-6"><strong>SURNAME:</strong> <span t-field="o.last_name"/></div>
                                    </div>
                                </td>
                            </tr>

                            <!-- Lower Section -->
                            <tr>
                                <td style="border: 1px solid #0077b6; padding: 4px;"><strong>SUM ASSURED:</strong> <br/>$<span t-field="o.sum_assured"/></td>
                                <td style="border: 1px solid #0077b6; padding: 4px;"><strong>PREMIUM:</strong> <br/>$<span t-field="o.premium_amount"/></td>
                                <td style="border: 1px solid #0077b6; padding: 4px;"><strong>AGENT:</strong> <br/><span t-field="o.agent_id.name"/></td>
                                <td style="border: 1px solid #0077b6; padding: 4px;"><strong>POLICY TERM:</strong> <br/><span t-field="o.policy_term"/></td>
                                <td style="border: 1px solid #0077b6; padding: 4px;">
                                    <div class="row">
                                        <div class="col-6"><strong>AGENT'S CODE:</strong> <br/><span t-field="o.agent_id.name"/></div>
                                        <div class="col-6"><strong>BRANCH:</strong> <br/><span t-field="o.branch_id.name"/></div>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" style="border: 1px solid #0077b6; padding: 4px;">
                                    <strong>WAITING PERIOD:</strong> 
                                    Y [ <t t-if="o.waiting_period">X</t> ] N [ <t t-if="not o.waiting_period">X</t> ]
                                </td>
                                <td colspan="3" style="border: 1px solid #0077b6; padding: 4px;">
                                    <strong>Benefits:</strong> 
                                    <t t-foreach="o.benefit_ids" t-as="b">
                                        <span style="margin-right: 15px;">[X] <t t-esc="b.name"/></span>
                                    </t>
                                </td>
                            </tr>

                            <!-- Beneficiaries Header -->
                            <tr>
                                <td colspan="5" style="border: 1px solid #0077b6; background-color: #f0f8ff; padding: 4px; font-weight: bold; text-align: center;">
                                    BENEFICIARIES <span style="font-weight: normal; font-size: 9px;">Policy holder, spouse, children to provide birth certificate copies on joining or upon death.</span>
                                </td>
                            </tr>
                            
                            <!-- Beneficiaries Grid -->
                            <tr style="background-color: #e6f2ff; font-weight: bold; text-align: center;">
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 5%;">#</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 25%;">SURNAME</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 25%;">FIRST NAME</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 15%;">RELATIONSHIP</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 15%;">D.O.B</td>
                            </tr>
                            
                            <t t-foreach="o.dependant_ids" t-as="dep">
                                <tr style="text-align: center;">
                                    <td style="border: 1px solid #0077b6; padding: 4px;"><span t-esc="dep_index + 1"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px; text-transform: uppercase;"><span t-field="dep.last_name"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px; text-transform: uppercase;"><span t-field="dep.first_name"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px; text-transform: uppercase;"><span t-field="dep.relationship"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px;"><span t-field="dep.dob"/></td>
                                </tr>
                            </t>
                            <t t-if="len(o.dependant_ids) &lt; 6">
                                <t t-foreach="range(6 - len(o.dependant_ids))" t-as="empty_row">
                                    <tr style="text-align: center; height: 25px;">
                                        <td style="border: 1px solid #0077b6; padding: 4px;"><span t-esc="len(o.dependant_ids) + empty_row + 1"/></td>
                                        <td style="border: 1px solid #0077b6;"></td><td style="border: 1px solid #0077b6;"></td>
                                        <td style="border: 1px solid #0077b6;"></td><td style="border: 1px solid #0077b6;"></td>
                                    </tr>
                                </t>
                            </t>
                        </table>

                        <div style="page-break-before: always;"></div>
                        
                        <!-- Page 2 (Back page with Declaration) -->
                        <table style="width: 100%; border-collapse: collapse; border: 2px solid #0077b6;">
                            <!-- Extended Family Grid -->
                            <tr>
                                <td colspan="5" style="border: 1px solid #0077b6; padding: 10px; background-color: #f0f8ff;">
                                    <h5 style="color: #0077b6; margin: 0; text-align: center;"><strong>Extended Family</strong></h5>
                                </td>
                            </tr>
                            <tr style="background-color: #e6f2ff; font-weight: bold; text-align: center;">
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 5%;">#</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 25%;">SURNAME</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 25%;">FIRST NAME</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 15%;">RELATIONSHIP</td>
                                <td style="border: 1px solid #0077b6; padding: 4px; width: 15%;">D.O.B</td>
                            </tr>
                            
                            <t t-foreach="o.extended_family_ids" t-as="ext">
                                <tr style="text-align: center;">
                                    <td style="border: 1px solid #0077b6; padding: 4px;"><span t-esc="ext_index + 7"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px; text-transform: uppercase;"><span t-field="ext.last_name"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px; text-transform: uppercase;"><span t-field="ext.first_name"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px; text-transform: uppercase;"><span t-field="ext.relationship"/></td>
                                    <td style="border: 1px solid #0077b6; padding: 4px;"><span t-field="ext.dob"/></td>
                                </tr>
                            </t>
                            <t t-if="len(o.extended_family_ids) &lt; 14">
                                <t t-foreach="range(14 - len(o.extended_family_ids))" t-as="empty_row">
                                    <tr style="text-align: center; height: 25px;">
                                        <td style="border: 1px solid #0077b6; padding: 4px;"><span t-esc="len(o.extended_family_ids) + empty_row + 7"/></td>
                                        <td style="border: 1px solid #0077b6;"></td><td style="border: 1px solid #0077b6;"></td>
                                        <td style="border: 1px solid #0077b6;"></td><td style="border: 1px solid #0077b6;"></td>
                                    </tr>
                                </t>
                            </t>

                            <!-- Declaration Header -->
                            <tr>
                                <td colspan="5" style="border: 1px solid #0077b6; padding: 10px;">
                                    <h5 style="color: #0077b6; margin-top: 0;"><strong>Declaration by proposer</strong></h5>
                                    <p style="font-size: 11px; margin-bottom: 30px;">
                                        I certify that the information supplied hereon is correct to the best of my knowledge. I have understood all the terms and conditions that have been explained to me and which are to be availed to me on the company's policy document.
                                    </p>
                                    
                                    <div class="row">
                                        <div class="col-7">
                                            <strong>Proposer's Signature:</strong> <span style="border-bottom: 1px solid black; display: inline-block; width: 200px;"></span>
                                        </div>
                                        <div class="col-5">
                                            <strong>Date:</strong> <span t-field="o.proposal_date" style="border-bottom: 1px solid black; display: inline-block; width: 150px;"/>
                                        </div>
                                    </div>
                                    <div class="row mt-4 mb-2">
                                        <div class="col-7">
                                            <strong>Signature of Agent:</strong> <span style="border-bottom: 1px solid black; display: inline-block; width: 200px;"></span>
                                        </div>
                                        <div class="col-5">
                                            <strong>Date:</strong> <span style="border-bottom: 1px solid black; display: inline-block; width: 150px;"></span>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            
                            <!-- Office Use -->
                            <tr>
                                <td colspan="5" style="border: 1px solid #0077b6; background-color: #f0f8ff; padding: 10px;">
                                    <h5 style="color: #0077b6; margin-top: 0;"><strong>For office use only</strong></h5>
                                    <div class="row">
                                        <div class="col-6">
                                            <strong>Underwriting decision</strong><br/><br/>
                                            <p>Accepted Loaded / Adjusted [ <t t-if="o.underwriting_decision == 'accepted'">X</t> ]</p>
                                            <p>Declined [ <t t-if="o.underwriting_decision == 'declined'">X</t> ]</p>
                                        </div>
                                        <div class="col-6">
                                            <strong>Underwriter</strong><br/><br/>
                                            <p>Initials: <span style="border-bottom: 1px solid black; display: inline-block; width: 150px;"></span></p>
                                            <p>Signature: <span style="border-bottom: 1px solid black; display: inline-block; width: 150px;"></span></p>
                                            <p>Date: <span style="border-bottom: 1px solid black; display: inline-block; width: 150px;"></span></p>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        </table>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
