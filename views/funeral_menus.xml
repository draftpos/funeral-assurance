<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Root Menu for App Switcher -->
        <menuitem id="menu_funeral_root"
                  name="Funeral Assurance"
                  web_icon="funeral_assurance,static/description/icon.png"
                  sequence="10"/>

        <!-- 1. Dashboard -->
        <menuitem id="menu_funeral_dashboard"
                  name="Dashboard"
                  parent="menu_funeral_root"
                  action="action_funeral_dashboard_window"
                  sequence="10"/>

        <!-- 2. Static Data -->
        <menuitem id="menu_funeral_static_data"
                  name="Static Data"
                  parent="menu_funeral_root"
                  sequence="20"/>

        <!-- 3. Operations -->
        <menuitem id="menu_funeral_operations"
                  name="Operations"
                  parent="menu_funeral_root"
                  sequence="30"/>

        <!-- 4. Compliance & Audit -->
        <menuitem id="menu_funeral_compliance_audit"
                  name="Compliance &amp; Audit"
                  parent="menu_funeral_root"
                  sequence="40"/>


        <!-- 5. Tombstones -->
        <menuitem id="menu_funeral_tombstones"
                  name="Tombstones"
                  parent="menu_funeral_root"
                  sequence="50"/>

        <!-- 6. Vehicles -->
        <menuitem id="menu_funeral_vehicles"
                  name="Vehicles"
                  parent="menu_funeral_root"
                  sequence="60"/>

        <!-- 7. Reports -->
        <menuitem id="menu_funeral_reports"
                  name="Reports"
                  parent="menu_funeral_root"
                  sequence="70"/>

        <!-- Report Categories -->
        <menuitem id="menu_report_cat_operations" name="Operations" parent="menu_funeral_reports" sequence="10"/>
        <menuitem id="menu_report_cat_tombstones" name="Tombstones" parent="menu_funeral_reports" sequence="20"/>
        <menuitem id="menu_report_cat_audit" name="Audit and Compliance" parent="menu_funeral_reports" sequence="30"/>
        <menuitem id="menu_report_cat_vehicles" name="Vehicles" parent="menu_funeral_reports" sequence="40"/>
        
        <!-- 8. User Rights (formerly Configurations) -->
        <menuitem id="menu_funeral_configurations"
                  name="User Rights"
                  parent="menu_funeral_root"
                  sequence="80"/>

    </data>
</odoo>
