        <record id="view_funeral_control_right_form" model="ir.ui.view">
            <field name="name">funeral.control.right.form</field>
            <field name="model">funeral.control.right</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                                <field name="access_rights"/>
                            </group>
                            <group>
                                <field name="module_name"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_control_right" model="ir.actions.act_window">
            <field name="name">Control Rights</field>
            <field name="res_model">funeral.control.right</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_control_right" name="Control Rights" parent="menu_funeral_static_data" action="action_funeral_control_right" sequence="110"/>

        <!-- Admin Policies -->
        <record id="view_funeral_admin_policy_form" model="ir.ui.view">
            <field name="name">funeral.admin.policy.form</field>
            <field name="model">funeral.admin.policy</field>
            <field name="arch" type="xml">
                <form string="Admin Policy">
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="date_edited"/>
                                <field name="date_posted_to_history"/>
                                <field name="department_name"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="policy_description"/>
                                <field name="document_upload"/>
                                <field name="effective_date"/>
                                <field name="expiry_date"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_admin_policy" model="ir.actions.act_window">
