            <field name="model">funeral.optional.benefit</field>
            <field name="arch" type="xml">
                <list string="Optional Benefits">
                    <field name="name"/>
                    <field name="premium_amount"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>
        <record id="action_funeral_optional_benefit" model="ir.actions.act_window">
            <field name="name">Optional Benefits</field>
            <field name="res_model">funeral.optional.benefit</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_optional_benefit" name="Optional Benefits" parent="menu_funeral_static_data" action="action_funeral_optional_benefit" sequence="160"/>
