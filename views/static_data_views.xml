<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Regions -->
        <record id="view_funeral_region_form" model="ir.ui.view">
            <field name="name">funeral.region.form</field>
            <field name="model">funeral.region</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="description"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_region" model="ir.actions.act_window">
            <field name="name">Regions</field>
            <field name="res_model">funeral.region</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_region" name="Regions" parent="menu_funeral_static_data" action="action_funeral_region" sequence="30"/>

        <!-- Branches -->
        <record id="view_funeral_branch_form" model="ir.ui.view">
            <field name="name">funeral.branch.form</field>
            <field name="model">funeral.branch</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                                <field name="branch_code"/>
                                <field name="physical_address"/>
                                <field name="city_id"/>
                            </group>
                            <group>
                                <field name="region_id"/>
                                <field name="contact_number"/>
                                <field name="email_address"/>
                                <field name="branch_manager"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_branch" model="ir.actions.act_window">
            <field name="name">Branches</field>
            <field name="res_model">funeral.branch</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_branch" name="Branches" parent="menu_funeral_static_data" action="action_funeral_branch" sequence="40"/>

        <!-- Gender -->
        <record id="view_funeral_gender_form" model="ir.ui.view">
            <field name="name">funeral.gender.form</field>
            <field name="model">funeral.gender</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="description"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_gender" model="ir.actions.act_window">
            <field name="name">Gender</field>
            <field name="res_model">funeral.gender</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_gender" name="Gender" parent="menu_funeral_static_data" action="action_funeral_gender" sequence="50"/>

        <!-- Agent Category -->
        <record id="view_funeral_agent_category_form" model="ir.ui.view">
            <field name="name">funeral.agent.category.form</field>
            <field name="model">funeral.agent.category</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="commission_structure"/>
                                <field name="description"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_agent_category" model="ir.actions.act_window">
            <field name="name">Agent Categories</field>
            <field name="res_model">funeral.agent.category</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_agent_category" name="Agent Categories" parent="menu_funeral_static_data" action="action_funeral_agent_category" sequence="60"/>

        <!-- Products -->
        <record id="view_funeral_product_form" model="ir.ui.view">
            <field name="name">funeral.product.form</field>
            <field name="model">funeral.product</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                                <field name="product_description"/>
                                <field name="coverage_details"/>
                                <field name="premium_structure"/>
                            </group>
                            <group>
                                <field name="eligibility_criteria"/>
                                <field name="effective_date"/>
                                <field name="expiry_date"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_funeral_product_list" model="ir.ui.view">
            <field name="name">funeral.product.list</field>
            <field name="model">funeral.product</field>
            <field name="arch" type="xml">
                <list string="Products">
                    <field name="name"/>
                    <field name="product_description"/>
                    <field name="eligibility_criteria"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>
        <record id="action_funeral_product" model="ir.actions.act_window">
            <field name="name">Products</field>
            <field name="res_model">funeral.product</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_product" name="Products" parent="menu_funeral_static_data" action="action_funeral_product" sequence="70"/>

        <!-- Product Rates -->
        <record id="view_funeral_product_rate_form" model="ir.ui.view">
            <field name="name">funeral.product.rate.form</field>
            <field name="model">funeral.product.rate</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="product_id"/>
                                <field name="age_range"/>
                                <field name="premium_amount"/>
                            </group>
                            <group>
                                <field name="coverage_amount"/>
                                <field name="effective_date"/>
                                <field name="expiry_date"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_funeral_product_rate_list" model="ir.ui.view">
            <field name="name">funeral.product.rate.list</field>
            <field name="model">funeral.product.rate</field>
            <field name="arch" type="xml">
                <list string="Product Rates">
                    <field name="product_id"/>
                    <field name="age_range"/>
                    <field name="premium_amount"/>
                    <field name="coverage_amount"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>
        <record id="action_funeral_product_rate" model="ir.actions.act_window">
            <field name="name">Product Rates</field>
            <field name="res_model">funeral.product.rate</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_product_rate" name="Product Rates" parent="menu_funeral_static_data" action="action_funeral_product_rate" sequence="80"/>

        <!-- Commission Rates -->
        <record id="view_funeral_commission_rate_form" model="ir.ui.view">
            <field name="name">funeral.commission.rate.form</field>
            <field name="model">funeral.commission.rate</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="agent_category_id"/>
                                <field name="product_id"/>
                                <field name="commission_percentage"/>
                            </group>
                            <group>
                                <field name="effective_date"/>
                                <field name="expiry_date"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_commission_rate" model="ir.actions.act_window">
            <field name="name">Commission Rates</field>
            <field name="res_model">funeral.commission.rate</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_commission_rate" name="Commission Rates" parent="menu_funeral_static_data" action="action_funeral_commission_rate" sequence="90"/>

