        <!-- Targets -->
        <record id="view_funeral_target_form" model="ir.ui.view">
            <field name="name">funeral.target.form</field>
            <field name="model">funeral.target</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="agent_id"/>
                                <field name="category_id"/>
                                <field name="written_daily_target"/>
                                <field name="written_weekly_target"/>
                                <field name="written_monthly_target"/>
                                <field name="written_annual_target"/>
                                <field name="collection_daily_target"/>
                            </group>
                            <group>
                                <field name="collection_weekly_target"/>
                                <field name="collection_monthly_target"/>
                                <field name="collection_annual_target"/>
                                <field name="conversion_daily_target"/>
                                <field name="conversion_weekly_target"/>
                                <field name="conversion_monthly_target"/>
                                <field name="conversion_annual_target"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_target" model="ir.actions.act_window">
            <field name="name">Targets</field>
            <field name="res_model">funeral.target</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_target" name="Targets" parent="menu_funeral_static_data" action="action_funeral_target" sequence="130"/>

