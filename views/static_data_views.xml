        <record id="view_funeral_agent_commission_rate_form" model="ir.ui.view">
            <field name="name">funeral.agent.commission.rate.form</field>
            <field name="model">funeral.agent.commission.rate</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="agent_id"/>
                            </group>
                            <group>
                                <field name="agent_category_id"/>
                                <field name="commissions_rates"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_agent_commission_rate" model="ir.actions.act_window">
            <field name="name">Agent Commission Rates</field>
            <field name="res_model">funeral.agent.commission.rate</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_agent_commission_rate" name="Agent Commission Rates" parent="menu_funeral_static_data" action="action_funeral_agent_commission_rate" sequence="140"/>

