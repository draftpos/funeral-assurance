                                <field name="capture_date"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="description"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_funeral_policy_status" model="ir.actions.act_window">
            <field name="name">Policy Statuses</field>
            <field name="res_model">funeral.policy.status</field>
            <field name="view_mode">list,form</field>
        </record>
        <menuitem id="menu_funeral_policy_status" name="Policy Statuses" parent="menu_funeral_static_data" action="action_funeral_policy_status" sequence="100"/>

