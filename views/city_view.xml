<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_funeral_city_form" model="ir.ui.view">
            <field name="name">funeral.city.form</field>
            <field name="model">funeral.city</field>
            <field name="arch" type="xml">
                <form string="City">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="region_id"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_funeral_city_list" model="ir.ui.view">
            <field name="name">funeral.city.list</field>
            <field name="model">funeral.city</field>
            <field name="arch" type="xml">
                <list string="Cities">
                    <field name="name"/>
                    <field name="region_id"/>
                    <field name="capture_date"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="action_funeral_city" model="ir.actions.act_window">
            <field name="name">Cities</field>
            <field name="res_model">funeral.city</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_funeral_city"
                  name="Cities"
                  parent="menu_funeral_static_data"
                  action="action_funeral_city"
                  sequence="20"/>
    </data>
</odoo>
