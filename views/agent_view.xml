<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_funeral_agent_form" model="ir.ui.view">
            <field name="name">funeral.agent.form</field>
            <field name="model">funeral.agent</field>
            <field name="arch" type="xml">
                <form string="Agent">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                        <group>
                            <group>
                                <field name="capture_date"/>
                                <field name="first_name"/>
                                <field name="last_name"/>
                                <field name="national_id"/>
                                <field name="contact_number"/>
                                <field name="email"/>
                                <field name="physical_address"/>
                            </group>
                            <group>
                                <field name="city_id"/>
                                <field name="region_id"/>
                                <field name="branch_id"/>
                                <field name="agent_category_id"/>
                                <field name="engagement_date"/>
                                <field name="active"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_funeral_agent_list" model="ir.ui.view">
            <field name="name">funeral.agent.list</field>
            <field name="model">funeral.agent</field>
            <field name="arch" type="xml">
                <list string="Agents">
                    <field name="capture_date" optional="hide"/>
                    <field name="first_name" optional="show"/>
                    <field name="last_name" optional="show"/>
                    <field name="national_id" optional="show"/>
                    <field name="contact_number" optional="show"/>
                    <field name="email" optional="hide"/>
                    <field name="physical_address" optional="hide"/>
                    <field name="city_id" optional="show"/>
                    <field name="region_id" optional="hide"/>
                    <field name="branch_id" optional="hide"/>
                    <field name="agent_category_id" optional="show"/>
                    <field name="engagement_date" optional="hide"/>
                    <field name="active" optional="show"/>
                </list>
            </field>
        </record>

        <record id="action_funeral_agent" model="ir.actions.act_window">
            <field name="name">Agents</field>
            <field name="res_model">funeral.agent</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_funeral_agent"
                  name="Agents"
                  parent="menu_funeral_static_data"
                  action="action_funeral_agent"
                  sequence="10"/>
    </data>
</odoo>
