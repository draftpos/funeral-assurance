<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_funeral_proposal_form" model="ir.ui.view">
            <field name="name">funeral.proposal.form</field>
            <field name="model">funeral.proposal</field>
            <field name="arch" type="xml">
                <form string="Proposal">
                    <header>
                        <button name="action_print_proposal" string="Preview Pdf" type="object" class="btn-primary"/>
                        <button name="action_create_payment" string="New Payment" type="object" class="btn-secondary"/>
                        <field name="state" widget="statusbar" statusbar_visible="pending,accepted,active,lapse,ntu"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="proposal_date"/>
                            </group>
                            <group>
                                <field name="partner_id" invisible="partner_id == False"/>
                            </group>
                        </group>
                        <div class="row">
                            <div class="col-md-4">
                                <group string="Personal Details">
                                    <field name="title"/>
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                    <field name="national_id"/>
                                    <field name="is_override_id"/>
                                    <field name="dob"/>
                                    <field name="gender_id"/>
                                    <field name="marital_status"/>
                                    <field name="next_of_kin"/>
                                </group>
                            </div>
                            <div class="col-md-4">
                                <group string="Contact Details">
                                    <field name="home_phone"/>
                                    <field name="business_phone"/>
                                    <field name="email"/>
                                    <field name="residential_address"/>
                                    <field name="business_address"/>
                                </group>
                            </div>
                            <div class="col-md-4">
                                <group string="Employment Details">
                                    <field name="employer"/>
                                    <field name="occupation"/>
                                    <field name="ec_number"/>
                                    <field name="gross_salary"/>
                                    <field name="net_salary"/>
                                </group>
                            </div>
                        </div>
                        
                        <notebook>
                            <page string="Policy &amp; Underwriting Details">
                                <group>
                                    <group string="Policy Cover Details">
                                        <field name="product_id"/>
                                        <field name="plan_type"/>
                                        <field name="premium_amount"/>
                                        <field name="total_premium" readonly="1"/>
                                        <field name="sum_assured"/>
                                        <field name="policy_term"/>
                                        <field name="waiting_period"/>
                                    </group>
                                    <group string="Agent &amp; Payment Setup">
                                        <field name="agent_id"/>
                                        <field name="branch_id"/>
                                        <field name="mode_of_payment"/>
                                        <field name="frequency"/>
                                        <field name="first_payment_date"/>
                                    </group>
                                </group>

                                <group string="Underwriting &amp; Declaration">
                                    <field name="underwriting_decision"/>
                                    <field name="status_id"/>
                                </group>
                                <group string="Policy Status &amp; Tracking">
                                    <field name="paid_up_to"/>
                                    <field name="is_in_arrears"/>
                                    <field name="months_paid_to_agent"/>
                                    <field name="commencement_date"/>
                                    <field name="policy_document"/>
                                    <field name="cancellation_reason"/>
                                </group>
                            </page>
                            <page string="Beneficiaries / Dependants">
                                <field name="dependant_ids">
                                    <list editable="bottom">
                                        <field name="last_name" optional="show"/>
                                        <field name="first_name" optional="show"/>
                                        <field name="relationship" optional="show"/>
                                        <field name="dob" optional="show"/>
                                        <field name="national_id" optional="show"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Extended Families">
                                <field name="extended_family_ids">
                                    <list editable="bottom">
                                        <field name="last_name" optional="show"/>
                                        <field name="first_name" optional="show"/>
                                        <field name="relationship_id" optional="show"/>
                                        <field name="dob" optional="show"/>
                                        <field name="national_id" optional="show"/>
                                        <field name="extended_premium_amount" optional="show"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Benefits">
                                <field name="benefit_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="benefit_type"/>
                                        <field name="premium_amount" invisible="benefit_type == 'mandatory'"/>
                                        <field name="beneficial_amount" invisible="benefit_type == 'mandatory'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_funeral_proposal_tree" model="ir.ui.view">
            <field name="name">funeral.proposal.tree</field>
            <field name="model">funeral.proposal</field>
            <field name="arch" type="xml">
                <list string="Proposals">
                    <field name="name" optional="show"/>
                    <field name="proposal_date" optional="hide"/>
                    <field name="title" optional="hide"/>
                    <field name="first_name" optional="hide"/>
                    <field name="last_name" optional="hide"/>
                    <field name="full_name" optional="show"/>
                    <field name="national_id" optional="show"/>
                    <field name="home_phone" optional="show"/>
                    <field name="email" optional="hide"/>
                    <field name="product_id" optional="hide"/>
                    <field name="plan_type" optional="show"/>
                    <field name="premium_amount" optional="show"/>
                    <field name="sum_assured" optional="hide"/>
                    <field name="agent_id" optional="hide"/>
                    <field name="branch_id" optional="hide"/>
                    <field name="state" optional="show" widget="badge" decoration-info="state == 'pending'" decoration-success="state == 'accepted'" decoration-danger="state == 'rejected'" decoration-muted="state == 'ntu'"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_funeral_proposal_search" model="ir.ui.view">
            <field name="name">funeral.proposal.search</field>
            <field name="model">funeral.proposal</field>
            <field name="arch" type="xml">
                <search string="Search Proposals">
                    <field name="name"/>
                    <field name="full_name"/>
                    <field name="national_id"/>
                    <field name="home_phone"/>
                    <field name="plan_type"/>
                    <field name="state"/>
                    <field name="agent_id"/>
                    <field name="branch_id"/>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_funeral_proposal" model="ir.actions.act_window">
            <field name="name">Proposals</field>
            <field name="res_model">funeral.proposal</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_funeral_proposal_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Proposal
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_funeral_proposal"
                  name="Proposals"
                  parent="menu_funeral_operations"
                  action="action_funeral_proposal"
                  sequence="2"/>
                  
        <!-- Action for Active Policies -->
        <record id="action_funeral_active_policies" model="ir.actions.act_window">
            <field name="name">Active Policies</field>
            <field name="res_model">funeral.proposal</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('state', '=', 'active')]</field>
            <field name="context">{'default_state': 'active'}</field>
        </record>

        <!-- Menu Item for Active Policies -->
        <menuitem id="menu_funeral_active_policies"
                  name="View Policies"
                  parent="menu_funeral_root"
                  action="action_funeral_active_policies"
                  sequence="35"/>
                  
        <!-- Action for Status Update -->
        <record id="action_funeral_status_update" model="ir.actions.act_window">
            <field name="name">Status Updates</field>
            <field name="res_model">funeral.proposal</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Item for Status Update (Between Claims and Commissions) -->
        <menuitem id="menu_funeral_status_update"
                  name="Status Update"
                  parent="menu_funeral_operations"
                  action="action_funeral_status_update"
                  sequence="10"/>
    </data>
</odoo>
