<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Property Valuation -->
        <record id="view_funeral_property_valuation_form" model="ir.ui.view">
            <field name="name">funeral.property.valuation.form</field>
            <field name="model">funeral.property.valuation</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Property Details">
                                <field name="property_type"/>
                                <field name="evaluator"/>
                            </group>
                            <group string="Valuation Tracking">
                                <field name="last_valuation_date"/>
                                <field name="last_valuation_amount"/>
                                <field name="next_valuation_due"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_funeral_property_valuation_list" model="ir.ui.view">
            <field name="name">funeral.property.valuation.list</field>
            <field name="model">funeral.property.valuation</field>
            <field name="arch" type="xml">
                <list string="Property Valuations" decoration-danger="status == 'overdue'" decoration-warning="status == 'due_soon'">
                    <field name="name" optional="show"/>
                    <field name="property_type" optional="show"/>
                    <field name="last_valuation_amount" optional="show"/>
                    <field name="next_valuation_due" optional="show"/>
                    <field name="status" optional="show" widget="badge"/>
                </list>
            </field>
        </record>
        
        <record id="action_funeral_property_valuation" model="ir.actions.act_window">
            <field name="name">Property Valuations</field>
            <field name="res_model">funeral.property.valuation</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Commissioner Data -->
        <record id="view_funeral_commissioner_data_form" model="ir.ui.view">
            <field name="name">funeral.commissioner.data.form</field>
            <field name="model">funeral.commissioner.data</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="submission_status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="report_type"/>
                                <field name="report_date"/>
                                <field name="prepared_by"/>
                            </group>
                            <group>
                                <field name="file_name" invisible="1"/>
                                <field name="attachment" filename="file_name"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_funeral_commissioner_data_list" model="ir.ui.view">
            <field name="name">funeral.commissioner.data.list</field>
            <field name="model">funeral.commissioner.data</field>
            <field name="arch" type="xml">
                <list string="Commissioner Data">
                    <field name="name" optional="show"/>
                    <field name="report_type" optional="show"/>
                    <field name="report_date" optional="show"/>
                    <field name="submission_status" optional="show" widget="badge"/>
                </list>
            </field>
        </record>
        
        <record id="action_funeral_commissioner_data" model="ir.actions.act_window">
            <field name="name">Commissioner Reporting</field>
            <field name="res_model">funeral.commissioner.data</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Actuary Data -->
        <record id="view_funeral_actuary_data_form" model="ir.ui.view">
            <field name="name">funeral.actuary.data.form</field>
            <field name="model">funeral.actuary.data</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="actuary_name"/>
                                <field name="valuation_date"/>
                                <field name="data_period_start"/>
                                <field name="data_period_end"/>
                            </group>
                            <group string="Metrics">
                                <field name="total_liabilities"/>
                                <field name="solvency_ratio"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Findings &amp; Recommendations">
                                <group>
                                    <field name="findings"/>
                                    <field name="recommendations"/>
                                </group>
                            </page>
                            <page string="Attachment">
                                <field name="file_name" invisible="1"/>
                                <field name="attachment" filename="file_name"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_funeral_actuary_data_list" model="ir.ui.view">
            <field name="name">funeral.actuary.data.list</field>
            <field name="model">funeral.actuary.data</field>
            <field name="arch" type="xml">
                <list string="Actuarial Reports">
                    <field name="name" optional="show"/>
                    <field name="actuary_name" optional="show"/>
                    <field name="valuation_date" optional="show"/>
                    <field name="solvency_ratio" optional="show"/>
                    <field name="status" optional="show" widget="badge"/>
                </list>
            </field>
        </record>
        
        <record id="action_funeral_actuary_data" model="ir.actions.act_window">
            <field name="name">Actuarial Data</field>
            <field name="res_model">funeral.actuary.data</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Auditor Data -->
        <record id="view_funeral_auditor_data_form" model="ir.ui.view">
            <field name="name">funeral.auditor.data.form</field>
            <field name="model">funeral.auditor.data</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="status" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name"/></h1>
                        </div>
                        <group>
                            <group string="Auditor Info">
                                <field name="auditor_name"/>
                                <field name="financial_year"/>
                            </group>
                            <group string="Dates">
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                            <group string="Results">
                                <field name="audit_opinion"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Key Audit Matters">
                                <field name="key_audit_matters"/>
                            </page>
                            <page string="Management Letter">
                                <field name="file_name" invisible="1"/>
                                <field name="management_letter" filename="file_name"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="view_funeral_auditor_data_list" model="ir.ui.view">
            <field name="name">funeral.auditor.data.list</field>
            <field name="model">funeral.auditor.data</field>
            <field name="arch" type="xml">
                <list string="Audit Reports">
                    <field name="name" optional="show"/>
                    <field name="auditor_name" optional="show"/>
                    <field name="financial_year" optional="show"/>
                    <field name="status" optional="show" widget="badge"/>
                </list>
            </field>
        </record>
        
        <record id="action_funeral_auditor_data" model="ir.actions.act_window">
            <field name="name">Auditor Data</field>
            <field name="res_model">funeral.auditor.data</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menus -->
                  
        <menuitem id="menu_funeral_commissioner"
                  name="Commissioner Data"
                  parent="menu_funeral_compliance_audit"
                  action="action_funeral_commissioner_data"
                  sequence="10"/>

        <menuitem id="menu_funeral_actuary"
                  name="Actuarial Reports"
                  parent="menu_funeral_compliance_audit"
                  action="action_funeral_actuary_data"
                  sequence="20"/>

        <menuitem id="menu_funeral_auditor"
                  name="Audit Reports"
                  parent="menu_funeral_compliance_audit"
                  action="action_funeral_auditor_data"
                  sequence="30"/>
                  
        <menuitem id="menu_funeral_property"
                  name="Property Valuations"
                  parent="menu_funeral_compliance_audit"
                  action="action_funeral_property_valuation"
                  sequence="40"/>
    </data>
</odoo>
